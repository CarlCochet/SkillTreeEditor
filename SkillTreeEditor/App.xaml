<Application x:Class="SkillTreeEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SkillTreeEditor"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFF0F0F0" />
        <SolidColorBrush x:Key="AppPanelBrush" Color="#FF2A2A2A" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#FF3A3A3A" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#FF0078D4" />

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="#FF3A3A3A" />
            <Setter Property="Height" Value="1" />
        </Style>

        <!-- Default text style -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        </Style>

        <!-- Default window style -->
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        </Style>

        <!-- Default button style -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <!-- Default textbox style -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AppForegroundBrush}" />
        </Style>
    </Application.Resources>
</Application>